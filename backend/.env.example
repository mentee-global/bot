ENVIRONMENT=local
FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001

# OAuth client (issued by Mentee — see docs/oauth/00-oauth-overview.md §2.6)
MENTEE_OAUTH_ISSUER=http://localhost:8000
MENTEE_OAUTH_CLIENT_ID=mentee-bot-local
MENTEE_OAUTH_CLIENT_SECRET=
MENTEE_OAUTH_REDIRECT_URI=http://localhost:8001/api/auth/callback
MENTEE_OAUTH_SCOPES=openid email profile mentee.role

# Database (Postgres). Local dev: Railway public TCP proxy URL. Prod: postgres.railway.internal.
# Scheme must be postgresql+asyncpg:// for the async SQLAlchemy driver.
DATABASE_URL=postgresql+asyncpg://bot:bot@localhost:5432/bot_dev

# Session secrets. Generate the Fernet key once per environment:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_SECRET=
SESSION_COOKIE_NAME=mentee_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=604800

# OAuth transient state TTL (10 minutes)
OAUTH_STATE_TTL_SECONDS=600

# Optional
# OPENAI_API_KEY=
# PERPLEXITY_API_KEY=
