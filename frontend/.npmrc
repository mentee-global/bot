# Auth + registry config lives in .npmrc; everything else lives in
# pnpm-workspace.yaml (the canonical settings location in pnpm 11).
#
# `engine-strict` is npm-style and not enabled by default. Turning it on means
# any tool that respects `engines.node` (pnpm + npm) refuses to run on a Node
# version outside `>=22.12.0`, instead of silently producing a broken build.
engine-strict=true
